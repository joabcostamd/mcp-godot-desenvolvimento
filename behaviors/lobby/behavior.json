{
  "name": "lobby",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node que gerencia lobby multiplayer. Suporta max_players, game_mode e join/leave.",
  "synonyms": {
    "pt": [
      "lobby",
      "sala",
      "multiplayer",
      "partida"
    ],
    "en": [
      "lobby",
      "room",
      "multiplayer"
    ]
  },
  "parameters": [
    {
      "name": "max_players",
      "type": "int",
      "range": {
        "min": 2,
        "max": 64
      },
      "default": 4
    },
    {
      "name": "game_mode",
      "type": "String",
      "default": "default"
    }
  ],
  "signals": [
    {
      "name": "player_joined",
      "params": [
        {
          "name": "peer_id",
          "type": "int"
        }
      ]
    },
    {
      "name": "player_left",
      "params": [
        {
          "name": "peer_id",
          "type": "int"
        }
      ]
    },
    {
      "name": "game_started",
      "params": []
    }
  ],
  "dependencies": [
    "network_sync"
  ],
  "genres": [
    "multiplayer"
  ],
  "tags": [
    "multiplayer",
    "lobby"
  ],
  "combina_bem": [
    "network_sync",
    "state_machine",
    "hitbox",
    "object_pool",
    "tween_player",
    "health_bar",
    "floating_text",
    "sprite_animator"
  ],
  "custo": "leve",
  "verbo_pt": "criar_sala",
  "verbo_en": "create_lobby",
  "nivel": "intermediario",
  "preview_gif": "preview.gif",
  "preview_type": "abstract"
}
