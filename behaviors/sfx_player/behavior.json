{
  "name": "sfx_player",
  "description_pt": "Player de efeitos sonoros (SFX) one-shot. Toca um AudioStream com volume, pitch e bus configuráveis. Auto-limpeza ao terminar. play() ou play_stream(stream) para sobrescrever.",
  "description_en": "One-shot SFX player. Plays an AudioStream with configurable volume, pitch, and bus. Auto-cleanup on finish. play() or play_stream(stream) to override.",
  "synonyms": {
    "pt": [
      "som",
      "efeito",
      "sfx",
      "audio",
      "tocar"
    ],
    "en": [
      "sound",
      "effect",
      "sfx",
      "audio",
      "play"
    ]
  },
  "parameters": [
    {
      "name": "audio_stream",
      "type": "AudioStream",
      "description_pt": "Stream de áudio padrão.",
      "default": null
    },
    {
      "name": "volume_db",
      "type": "float",
      "description_pt": "Volume em dB.",
      "range": {
        "min": -80.0,
        "max": 24.0
      },
      "default": 0.0,
      "unit": "dB"
    },
    {
      "name": "pitch_scale",
      "type": "float",
      "description_pt": "Escala de pitch (1.0 = normal).",
      "range": {
        "min": 0.1,
        "max": 4.0
      },
      "default": 1.0
    },
    {
      "name": "bus",
      "type": "String",
      "description_pt": "Nome do bus de áudio.",
      "default": "SFX"
    },
    {
      "name": "auto_play",
      "type": "bool",
      "description_pt": "Se true, toca automaticamente ao entrar na árvore.",
      "default": false
    }
  ],
  "signals": [
    {
      "name": "played",
      "description_pt": "Emitido ao iniciar a reprodução.",
      "params": []
    },
    {
      "name": "finished",
      "description_pt": "Emitido ao terminar.",
      "params": []
    }
  ],
  "dependencies": [
    "audio_manager"
  ],
  "genres": [
    "generic"
  ],
  "conflicts": [],
  "version": "1.0.0",
  "godot_version": "4.7",
  "tags": [
    "audio",
    "sfx",
    "som",
    "efeito"
  ],
  "combina_bem": [
    "health",
    "audio_manager",
    "player_controller",
    "interactable",
    "collectable",
    "hitscan",
    "spawner_wave",
    "wave_system"
  ],
  "custo": "leve",
  "verbo_pt": "tocar_som",
  "verbo_en": "play_sfx",
  "nivel": "intermediario",
  "preview_gif": "preview.gif",
  "preview_type": "visual"
}
