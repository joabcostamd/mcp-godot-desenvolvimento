{
  "name": "rhythm_timing",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node que gerencia timing de ritmo. BPM configurável, janela de acerto (perfect/good/miss), input_action.",
  "synonyms": {
    "pt": [
      "ritmo",
      "batida",
      "musica",
      "timing"
    ],
    "en": [
      "rhythm",
      "beat",
      "music",
      "timing"
    ]
  },
  "parameters": [
    {
      "name": "bpm",
      "type": "float",
      "range": {
        "min": 30,
        "max": 300
      },
      "default": 120
    },
    {
      "name": "tolerance",
      "type": "float",
      "range": {
        "min": 0.01,
        "max": 0.5
      },
      "default": 0.1,
      "unit": "s"
    },
    {
      "name": "input_action",
      "type": "String",
      "default": "ui_accept"
    }
  ],
  "signals": [
    {
      "name": "perfect",
      "params": []
    },
    {
      "name": "good",
      "params": []
    },
    {
      "name": "miss",
      "params": []
    },
    {
      "name": "beat",
      "params": [
        {
          "name": "number",
          "type": "int"
        }
      ]
    }
  ],
  "genres": [
    "rhythm"
  ],
  "tags": [
    "rhythm"
  ],
  "combina_bem": [
    "state_machine",
    "hitbox",
    "object_pool",
    "tween_player",
    "health_bar",
    "floating_text",
    "sprite_animator",
    "status_effect"
  ],
  "custo": "medio",
  "verbo_pt": "sincronizar_ritmo",
  "verbo_en": "sync_rhythm",
  "nivel": "intermediario",
  "preview_gif": "preview.gif",
  "preview_type": "abstract"
}
