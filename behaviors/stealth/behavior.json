{
  "name": "stealth",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node que gerencia estado de furtividade. Visibility (0-1), noise_radius, detection_level. Emite sinais detected/alerted/hidden.",
  "synonyms": {
    "pt": [
      "furtivo",
      "esconder",
      "detectar",
      "sorrateiro"
    ],
    "en": [
      "stealth",
      "sneak",
      "hide",
      "detect"
    ]
  },
  "parameters": [
    {
      "name": "visibility",
      "type": "float",
      "range": {
        "min": 0,
        "max": 1
      },
      "default": 0.5
    },
    {
      "name": "noise_radius",
      "type": "float",
      "range": {
        "min": 0,
        "max": 500
      },
      "default": 100,
      "unit": "px"
    },
    {
      "name": "detection_decay",
      "type": "float",
      "default": 0.5
    }
  ],
  "signals": [
    {
      "name": "detected",
      "params": []
    },
    {
      "name": "alerted",
      "params": []
    },
    {
      "name": "hidden",
      "params": []
    }
  ],
  "genres": [
    "stealth"
  ],
  "tags": [
    "stealth"
  ],
  "combina_bem": [
    "state_machine",
    "hitbox",
    "object_pool",
    "tween_player",
    "health_bar",
    "floating_text",
    "sprite_animator",
    "status_effect"
  ],
  "custo": "medio",
  "verbo_pt": "esconder",
  "verbo_en": "hide",
  "nivel": "intermediario"
}
