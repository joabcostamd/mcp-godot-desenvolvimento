{
  "name": "settings",
  "description_pt": "Tela de configurações com sliders de volume (Master/Music/SFX), toggle fullscreen e seletor de idioma. CanvasLayer com VBoxContainer. Emite setting_changed. Usa save_load para persistência.",
  "description_en": "Settings screen with volume sliders (Master/Music/SFX), fullscreen toggle, and language selector. CanvasLayer with VBoxContainer. Emits setting_changed. Uses save_load for persistence.",
  "synonyms": {
    "pt": [
      "configuracoes",
      "opcoes",
      "audio",
      "video",
      "tela",
      "volume"
    ],
    "en": [
      "settings",
      "options",
      "audio",
      "video",
      "screen",
      "volume",
      "preferences"
    ]
  },
  "parameters": [
    {
      "name": "default_master_vol",
      "type": "float",
      "description_pt": "Volume Master padrão (dB).",
      "range": {
        "min": -80.0,
        "max": 24.0
      },
      "default": 0.0
    },
    {
      "name": "default_music_vol",
      "type": "float",
      "description_pt": "Volume Music padrão (dB).",
      "range": {
        "min": -80.0,
        "max": 24.0
      },
      "default": 0.0
    },
    {
      "name": "default_sfx_vol",
      "type": "float",
      "description_pt": "Volume SFX padrão (dB).",
      "range": {
        "min": -80.0,
        "max": 24.0
      },
      "default": 0.0
    },
    {
      "name": "show_fullscreen",
      "type": "bool",
      "description_pt": "Se true, mostra toggle fullscreen.",
      "default": true
    },
    {
      "name": "show_language",
      "type": "bool",
      "description_pt": "Se true, mostra seletor de idioma.",
      "default": false
    }
  ],
  "signals": [
    {
      "name": "setting_changed",
      "description_pt": "Emitido quando qualquer configuração muda.",
      "params": [
        {
          "name": "setting",
          "type": "String"
        },
        {
          "name": "value",
          "type": "Variant"
        }
      ]
    }
  ],
  "dependencies": [
    "save_load",
    "audio_manager"
  ],
  "genres": [
    "generic"
  ],
  "conflicts": [],
  "version": "1.0.0",
  "godot_version": "4.7",
  "tags": [
    "sistema",
    "configuracoes",
    "ui",
    "settings"
  ],
  "combina_bem": [
    "save_load",
    "audio_manager",
    "sfx_player",
    "ambience_zone",
    "screen_shake",
    "state_machine",
    "sprite_animator",
    "character_creator"
  ],
  "custo": "medio",
  "verbo_pt": "configurar",
  "verbo_en": "configure",
  "nivel": "intermediario",
  "preview_gif": "preview.gif",
  "preview_type": "visual",
  "preview_mp4": "preview.mp4"
}
