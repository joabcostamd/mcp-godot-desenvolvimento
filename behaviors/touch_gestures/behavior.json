{
  "name": "touch_gestures",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node que detecta gestos touch: swipe, pinch, long press, double tap.",
  "synonyms": {
    "pt": [
      "touch",
      "gesto",
      "swipe",
      "pinch"
    ],
    "en": [
      "touch",
      "gesture",
      "swipe",
      "pinch"
    ]
  },
  "parameters": [
    {
      "name": "swipe_threshold",
      "type": "float",
      "range": {
        "min": 10.0,
        "max": 200.0
      },
      "default": 50.0
    }
  ],
  "signals": [
    {
      "name": "swiped",
      "params": [
        {
          "name": "direction",
          "type": "Vector2"
        }
      ]
    },
    {
      "name": "pinched",
      "params": [
        {
          "name": "scale",
          "type": "float"
        }
      ]
    },
    {
      "name": "long_pressed",
      "params": [
        {
          "name": "position",
          "type": "Vector2"
        }
      ]
    },
    {
      "name": "double_tapped",
      "params": [
        {
          "name": "position",
          "type": "Vector2"
        }
      ]
    }
  ],
  "genres": [
    "mobile"
  ],
  "tags": [
    "touch"
  ],
  "combina_bem": [
    "state_machine",
    "hitbox",
    "object_pool",
    "tween_player",
    "health_bar",
    "floating_text",
    "sprite_animator",
    "status_effect"
  ],
  "custo": "medio",
  "verbo_pt": "detectar_gesto",
  "verbo_en": "detect_gesture",
  "nivel": "intermediario",
  "preview_gif": "preview.gif",
  "preview_type": "visual"
}
