{
  "name": "achievement_tracker",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node que rastreia conquistas com progresso e flags secretas. Integra com Achievement sibling. Ideal para sistemas de conquistas estilo Xbox/Steam.",
  "synonyms": {
    "pt": [
      "conquista",
      "achievement",
      "trofeu",
      "progresso"
    ],
    "en": [
      "achievement",
      "trophy",
      "progress"
    ]
  },
  "parameters": [
    {
      "name": "achievements",
      "type": "Array",
      "description_pt": "Array de {id,name,secret,target,icon}. target = valor para desbloquear."
    }
  ],
  "signals": [
    {
      "name": "unlocked",
      "params": [
        {
          "name": "id",
          "type": "String"
        }
      ]
    },
    {
      "name": "progress_updated",
      "params": [
        {
          "name": "id",
          "type": "String"
        },
        {
          "name": "progress",
          "type": "float"
        }
      ]
    }
  ],
  "dependencies": [
    "achievement"
  ],
  "genres": [
    "generic"
  ],
  "tags": [
    "achievement",
    "social"
  ]
}