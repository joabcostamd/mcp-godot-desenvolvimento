{
  "name": "behavior_tree",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node que executa uma árvore de comportamento (BT) simplificada com tick_rate configurável. Suporta Sequence, Selector e ações customizadas. Integra com Blackboard sibling para dados compartilhados.",
  "synonyms": {
    "pt": [
      "bt",
      "behavior_tree",
      "arvore",
      "comportamento",
      "ia"
    ],
    "en": [
      "bt",
      "behavior_tree",
      "tree",
      "ai"
    ]
  },
  "parameters": [
    {
      "name": "tick_rate",
      "type": "float",
      "range": {
        "min": 0.01,
        "max": 60.0
      },
      "default": 0.1
    },
    {
      "name": "tree_data",
      "type": "Array",
      "description_pt": "Array de nós: {type:sequence/selector/action, name, children, action_method}."
    }
  ],
  "signals": [
    {
      "name": "tree_started",
      "params": []
    },
    {
      "name": "tree_stopped",
      "params": []
    },
    {
      "name": "node_executed",
      "params": [
        {
          "name": "node_name",
          "type": "String"
        },
        {
          "name": "status",
          "type": "String"
        }
      ]
    }
  ],
  "dependencies": [
    "blackboard"
  ],
  "genres": [
    "generic"
  ],
  "tags": [
    "bt",
    "behavior_tree",
    "ia"
  ],
  "combina_bem": [
    "hurtbox",
    "hitbox",
    "health",
    "particle_impact",
    "sfx_player",
    "screen_shake",
    "object_pool",
    "tween_player"
  ],
  "custo": "medio",
  "verbo_pt": "decidir",
  "verbo_en": "decide",
  "nivel": "intermediario",
  "preview_gif": "preview.gif",
  "preview_type": "visual"
}
