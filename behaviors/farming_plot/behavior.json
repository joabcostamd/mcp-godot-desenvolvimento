{
  "name": "farming_plot",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node2D que gerencia plantio com estágios de crescimento e colheita.",
  "synonyms": {
    "pt": [
      "fazenda",
      "plantio",
      "colheita",
      "farm"
    ],
    "en": [
      "farming",
      "plot",
      "harvest",
      "grow"
    ]
  },
  "parameters": [
    {
      "name": "growth_time",
      "type": "float",
      "range": {
        "min": 1.0,
        "max": 600.0
      },
      "default": 30.0
