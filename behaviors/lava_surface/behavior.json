{
  "name": "lava_surface",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node2D que renderiza superfície de lava animada com shader. Suporta velocidade de fluxo, intensidade de brilho e cor. Ideal para jogos 2D com lava/ magma.",
  "synonyms": {
    "pt": [
      "lava",
      "magma",
      "fogo",
      "shader"
    ],
    "en": [
      "lava",
      "magma",
      "fire",
      "shader"
    ]
  },
  "parameters": [
    {
      "name": "flow_speed",
      "type": "float",
      "range": {
        "min": 0.1,
        "max": 10.0
      },
      "default": 0.5
    },
    {
      "name": "glow_intensity",
      "type": "float",
      "range": {
        "min": 0.1,
        "max": 5.0
      },
      "default": 1.5
    },
    {
      "name": "lava_color",
      "type": "Color",
      "default": {
        "r": 1.0,
        "g": 0.3,
        "b": 0.0,
        "a": 1.0
      }
    }
  ],
  "signals": [],
  "genres": [
    "platformer",
    "generic"
  ],
  "tags": [
    "lava",
    "shader"
  ],
  "combina_bem": [
    "save_load",
    "hurtbox",
    "health",
    "hitbox",
    "status_effect",
    "state_machine",
    "particle_impact",
    "sfx_player"
  ],
  "custo": "medio",
  "verbo_pt": "queimar",
  "verbo_en": "burn",
  "nivel": "basico"
}
