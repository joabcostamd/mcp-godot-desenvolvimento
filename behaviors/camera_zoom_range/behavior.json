{
  "name": "camera_zoom_range",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node que controla zoom contínuo da Camera2D com limites min/max e velocidade. Diferente de camera_zoom (#53) que faz zoom-to-target. Este oferece controle incremental com zoom_in/zoom_out.",
  "synonyms": {
    "pt": [
      "camera",
      "zoom",
      "range",
      "controle"
    ],
    "en": [
      "camera",
      "zoom",
      "range",
      "control"
    ]
  },
  "parameters": [
    {
      "name": "zoom_min",
      "type": "Vector2",
      "default": {
        "x": 0.5,
        "y": 0.5
      }
    },
    {
      "name": "zoom_max",
      "type": "Vector2",
      "default": {
        "x": 3.0,
        "y": 3.0
      }
    },
    {
      "name": "zoom_speed",
      "type": "float",
      "range": {
        "min": 0.1,
        "max": 10.0
      },
      "default": 2.0
    }
  ],
  "signals": [
    {
      "name": "zoomed",
      "params": [
        {
          "name": "new_zoom",
          "type": "Vector2"
        }
      ]
    }
  ],
  "genres": [
    "generic"
  ],
  "tags": [
    "camera",
    "zoom"
  ],
  "combina_bem": [
    "hurtbox",
    "hitbox",
    "health",
    "particle_impact",
    "sfx_player",
    "screen_shake",
    "object_pool",
    "tween_player"
  ],
  "custo": "medio",
  "verbo_pt": "zoom_range",
  "verbo_en": "zoom_range",
  "nivel": "basico",
  "preview_gif": "preview.gif",
  "preview_type": "visual",
  "preview_mp4": "preview.mp4"
}
