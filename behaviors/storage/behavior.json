{
  "name": "storage",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node que persiste dados em ConfigFile. Suporta tipos: int, float, string, bool, Vector2, Color. set_data/get_data com chave. Auto-save opcional com timer.",
  "description_en": "Node persisting data via ConfigFile. Supports int, float, string, bool, Vector2, Color. set_data/get_data with key. Optional auto-save with timer.",
  "synonyms": {
    "pt": [
      "dados",
      "persistencia",
      "config",
      "preferencias"
    ],
    "en": [
      "data",
      "persistence",
      "config",
      "preferences"
    ]
  },
  "parameters": [
    {
      "name": "file_path",
      "type": "String",
      "default": "user://storage.cfg"
    },
    {
      "name": "auto_save",
      "type": "bool",
      "default": true
    },
    {
      "name": "section",
      "type": "String",
      "default": "data"
    }
  ],
  "signals": [
    {
      "name": "data_changed",
      "params": [
        {
          "name": "key",
          "type": "String"
        }
      ]
    },
    {
      "name": "loaded",
      "params": []
    }
  ],
  "dependencies": [],
  "genres": [
    "generic"
  ],
  "tags": [
    "dados",
    "persistencia"
  ],
  "combina_bem": [
    "save_load",
    "health",
    "hitbox",
    "hurtbox",
    "particle_impact",
    "sfx_player",
    "screen_shake",
    "object_pool"
  ],
  "custo": "leve",
  "verbo_pt": "armazenar",
  "verbo_en": "store",
  "nivel": "intermediario",
  "preview_gif": "preview.gif",
  "preview_type": "visual"
}
