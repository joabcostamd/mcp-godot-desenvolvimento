{
  "name": "camera_lookat",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node que faz a Camera2D parent olhar para um alvo com offset e damping. Suave e configurável. Ideal para câmeras que seguem pontos de interesse.",
  "synonyms": {
    "pt": [
      "camera",
      "olhar",
      "lookat",
      "mirar",
      "alvo"
    ],
    "en": [
      "camera",
      "lookat",
      "look",
      "target"
    ]
  },
  "parameters": [
    {
      "name": "target",
      "type": "NodePath",
      "default": ""
    },
    {
      "name": "offset",
      "type": "Vector2",
      "default": {
        "x": 0,
        "y": 0
      }
    },
    {
      "name": "damping",
      "type": "float",
      "range": {
        "min": 0.01,
        "max": 1.0
      },
      "default": 0.1
    }
  ],
  "signals": [],
  "genres": [
    "platformer",
    "generic"
  ],
  "tags": [
    "camera",
    "lookat"
  ],
  "combina_bem": [
    "save_load",
    "hurtbox",
    "health",
    "hitbox",
    "status_effect",
    "state_machine",
    "particle_impact",
    "sfx_player"
  ],
  "custo": "medio",
  "verbo_pt": "olhar_para",
  "verbo_en": "look_at",
  "nivel": "basico"
}
