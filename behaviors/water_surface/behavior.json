{
  "name": "water_surface",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node2D que renderiza uma superfície de água animada com shader. Suporta velocidade de onda, amplitude, cor e distorção. Ideal para jogos 2D com água decorativa.",
  "synonyms": {
    "pt": [
      "agua",
      "water",
      "onda",
      "liquido",
      "shader"
    ],
    "en": [
      "water",
      "wave",
      "liquid",
      "shader"
    ]
  },
  "parameters": [
    {
      "name": "wave_speed",
      "type": "float",
      "range": {
        "min": 0.1,
        "max": 10.0
      },
      "default": 1.0
    },
    {
      "name": "wave_amplitude",
      "type": "float",
      "range": {
        "min": 0.5,
        "max": 20.0
      },
      "default": 5.0
    },
    {
      "name": "water_color",
      "type": "Color",
      "default": {
        "r": 0.1,
        "g": 0.3,
        "b": 0.8,
        "a": 0.7
      }
    }
  ],
  "signals": [],
  "genres": [
    "platformer",
    "generic"
  ],
  "tags": [
    "agua",
    "shader"
  ]
}