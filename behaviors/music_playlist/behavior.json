{
  "name": "music_playlist",
  "description_pt": "Playlist de música com suporte a shuffle, crossfade e navegação (next/prev). Toca streams no bus Music via AudioStreamPlayer. Emite track_changed e playlist_finished.",
  "description_en": "Music playlist with shuffle, crossfade, and navigation (next/prev). Plays streams on the Music bus via AudioStreamPlayer. Emits track_changed and playlist_finished.",
  "synonyms": {
    "pt": [
      "playlist",
      "musica",
      "trilha",
      "jukebox",
      "album"
    ],
    "en": [
      "playlist",
      "music",
      "soundtrack",
      "jukebox",
      "album"
    ]
  },
  "parameters": [
    {
      "name": "tracks",
      "type": "Array[AudioStream]",
      "description_pt": "Lista de streams de áudio.",
      "default": []
    },
    {
      "name": "shuffle",
      "type": "bool",
      "description_pt": "Se true, ordem aleatória.",
      "default": false
    },
    {
      "name": "crossfade_duration",
      "type": "float",
      "description_pt": "Duração do crossfade entre faixas (0 = sem).",
      "range": {
        "min": 0.0,
        "max": 5.0
      },
      "default": 0.0,
      "unit": "s"
    },
    {
      "name": "volume_db",
      "type": "float",
      "description_pt": "Volume em dB.",
      "range": {
        "min": -80.0,
        "max": 24.0
      },
      "default": 0.0
    },
    {
      "name": "auto_play",
      "type": "bool",
      "description_pt": "Se true, inicia ao entrar na árvore.",
      "default": false
    }
  ],
  "signals": [
    {
      "name": "track_changed",
      "description_pt": "Emitido ao trocar de faixa.",
      "params": [
        {
          "name": "track_index",
          "type": "int"
        }
      ]
    },
    {
      "name": "playlist_finished",
      "description_pt": "Emitido ao terminar a última faixa.",
      "params": []
    }
  ],
  "dependencies": [
    "audio_manager"
  ],
  "genres": [
    "generic"
  ],
  "conflicts": [],
  "version": "1.0.0",
  "godot_version": "4.7",
  "tags": [
    "audio",
    "musica",
    "playlist",
    "trilha"
  ],
  "combina_bem": [
    "audio_manager",
    "sfx_player",
    "health",
    "hitbox",
    "hurtbox",
    "ambience_zone",
    "particle_impact",
    "settings"
  ],
  "custo": "leve",
  "verbo_pt": "tocar_musica",
  "verbo_en": "play_music",
  "nivel": "intermediario",
  "preview_gif": "preview.gif",
  "preview_type": "visual",
  "preview_mp4": "preview.mp4"
}
