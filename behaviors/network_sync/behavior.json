{
  "name": "network_sync",
  "version": "1.0.0",
  "godot_version": "4.7",
  "description_pt": "Node que sincroniza propriedades entre peers via multiplayer. Suporta sync_interval configurável e detecção de dessincronização.",
  "synonyms": {
    "pt": [
      "sync",
      "sincronizacao",
      "multiplayer",
      "rede"
    ],
    "en": [
      "sync",
      "network",
      "multiplayer"
    ]
  },
  "parameters": [
    {
      "name": "sync_interval",
      "type": "float",
      "range": {
        "min": 0.01,
        "max": 5.0
      },
      "default": 0.1
    }
  ],
  "signals": [
    {
      "name": "synced",
      "params": []
    },
    {
      "name": "desync_detected",
      "params": []
    }
  ],
  "genres": [
    "multiplayer"
  ],
  "tags": [
    "multiplayer",
    "sync"
  ]
}