; Minimal project.godot para validação de scripts do Agente 2 + GdUnit4.
; Não é um projeto real — serve para Godot --headless --quit e testes GdUnit4.

config_version=5

[application]

config/name="agente2_validate"
config/version="0.0.1"
config/features=PackedStringArray("4.7")

[editor_plugins]

enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg")
