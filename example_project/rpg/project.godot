; RPG — MCP Godot Agent Example
; Godot 4.7 | Top-Down 2D Action RPG
; 20 behaviors | 5 scenes

[application]
config/name="MCP Example - RPG"
config/description="RPG top-down 2D: explore, combata slimes, ganhe XP, fale com NPCs, complete missoes. 20 behaviors do arsenal MCP."
config/features=PackedStringArray("2d")
run/main_scene="res://scenes/menu.tscn"

[display]
window/size/viewport_width=480
window/size/viewport_height=270
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]
environment/default_clear_color=Color(0.15, 0.2, 0.1, 1)

[editor_plugins]
enabled=PackedStringArray("res://addons/mcp_addon/plugin.cfg", "res://addons/mcp_dock/plugin.cfg")
