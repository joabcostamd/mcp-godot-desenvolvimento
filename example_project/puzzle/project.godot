; Puzzle — MCP Godot Agent Example
; Godot 4.7 | Grid-Based Sokoban-like
; 10 behaviors | 3 scenes

[application]
config/name="MCP Example - Puzzle"
config/description="Puzzle estilo Sokoban: empurre caixas para posicoes alvo num grid. 10 behaviors do arsenal MCP."
config/features=PackedStringArray("2d")
run/main_scene="res://scenes/menu.tscn"

[display]
window/size/viewport_width=480
window/size/viewport_height=270
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]
environment/default_clear_color=Color(0.1, 0.1, 0.15, 1)

[editor_plugins]
enabled=PackedStringArray("res://addons/mcp_addon/plugin.cfg", "res://addons/mcp_dock/plugin.cfg")
