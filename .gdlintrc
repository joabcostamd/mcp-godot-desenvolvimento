# .gdlintrc — Configuracao gdlint 4.5.0 para MCP Godot (Fatia 4.3)
# Formato: YAML (nao INI/TOML!)
# Gerado a partir de: gdlint -d (dump default config)
# Documentacao: https://github.com/Scony/godot-gdscript-toolkit
#
# Regras com valor "null" = habilitadas com comportamento padrao.
# Para desabilitar uma regra, adicione-a em "disable".
# Severidade NAO e configuravel por regra no gdlint 4.x.

# ── Definicoes de Ordem de Classe ──────────────────────────────
class-definitions-order:
- tools
- classnames
- extends
- docstrings
- signals
- enums
- consts
- staticvars
- exports
- pubvars
- prvvars
- onreadypubvars
- onreadyprvvars
- others

# ── Nomeacao (regex patterns GDScript oficial) ─────────────────
class-name: ([A-Z][a-z0-9]*)+
class-variable-name: _?[a-z][a-z0-9]*(_[a-z0-9]+)*
constant-name: _?[A-Z][A-Z0-9]*(_[A-Z0-9]+)*
enum-name: ([A-Z][a-z0-9]*)+
enum-element-name: '[A-Z][A-Z0-9]*(_[A-Z0-9]+)*'
function-name: (_on_([A-Z][a-z0-9]*)+(_[a-z0-9]+)*|_?[a-z][a-z0-9]*(_[a-z0-9]+)*)
function-argument-name: _?[a-z][a-z0-9]*(_[a-z0-9]+)*
function-variable-name: '[a-z][a-z0-9]*(_[a-z0-9]+)*'
loop-variable-name: _?[a-z][a-z0-9]*(_[a-z0-9]+)*
signal-name: '[a-z][a-z0-9]*(_[a-z0-9]+)*'
sub-class-name: _?([A-Z][a-z0-9]*)+
class-load-variable-name: (([A-Z][a-z0-9]*)+|_?[a-z][a-z0-9]*(_[a-z0-9]+)*)
function-preload-variable-name: ([A-Z][a-z0-9]*)+
load-constant-name: (([A-Z][a-z0-9]*)+|_?[A-Z][A-Z0-9]*(_[A-Z0-9]+)*)

# ── Limiares de Qualidade (ajustados para o projeto) ───────────
max-file-lines: 1000
max-line-length: 100
max-public-methods: 20
max-returns: 6
function-arguments-number: 10

# ── Regras Habilitadas (null = habilitado) ─────────────────────
comparison-with-itself: null
duplicated-load: null
expression-not-assigned: null
mixed-tabs-and-spaces: null
no-elif-return: null
no-else-return: null
tab-characters: 1
trailing-whitespace: null
unnecessary-pass: null
unused-argument: null

# ── Diretorios Excluidos ───────────────────────────────────────
excluded_directories:
  .git: null
  addons: null
  .godot: null

# ── Regras Desabilitadas ───────────────────────────────────────
disable: []

